{
  "Action": {
    "body": "#action/",
    "description": "Action",
    "prefix": "act"
  },
  "Action Todo": {
    "body": "#action/todo",
    "description": "Action Todo",
    "prefix": "atd"
  },
  "Attempt": {
    "body": "### Attempt $0, ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}, ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
    "description": "10x10x10 Attempt",
    "prefix": "att"
  },
  "Connection Tag": {
    "body": "#action/connection",
    "description": "Connection Tag",
    "prefix": "conn"
  },
  "Creates a Road Map": {
    "body": [
      "# 🛣️️ Road-map",
      "",
      "> [👈 Back to README](./README.md)",
      "",
      "## 🎒 Backlog",
      "",
      "- [ ] Here 🙋",
      "",
      "---",
      "",
      "## 🗃️ Archive"
    ],
    "description": "Creates a Road Map",
    "prefix": "roadmap"
  },
  "Footer": {
    "body": ["# 🌟 See Also", "", "- …", "", "# 🧬 References", "", "- …"],
    "description": "Footer for my permanent notes",
    "prefix": "footer"
  },
  "High Performance Person": {
    "body": "High Performance Person",
    "prefix": "hpp"
  },
  "Markdown Link": {
    "body": "[$0]($CLIPBOARD)",
    "description": "Creates a markdown link",
    "prefix": "ml"
  },
  "References": {
    "body": ["# 🧬 References", "", "- $0"],
    "prefix": "references"
  },
  "Research Action": {
    "body": "#action/research $0",
    "description": "Research Action",
    "prefix": "rsc"
  },
  "See Also": {
    "body": ["# 🌟 See Also", "", "- $0"],
    "prefix": "see also"
  },
  "Sparking Idea": {
    "body": "**Sparking Idea** - $0",
    "description": "Write a sparking idea while I'm in the middle of a literature note",
    "prefix": "sp"
  },
  "Task Canceled": {
    "body": ["❌ ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"],
    "description": "Tasks Canceled",
    "prefix": "canceled"
  },
  "Task Created": {
    "body": ["➕ ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"],
    "description": "Tasks Created",
    "prefix": "created"
  },
  "Task Done": {
    "body": ["✅ ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"],
    "description": "Tasks Done",
    "prefix": "done"
  },
  "Task Due Date": {
    "body": ["<@$0>"],
    "description": "Task Due Date",
    "prefix": "due"
  },
  "Todos": {
    "body": ["# ✅ TODOs", "", "- [ ] $0"],
    "prefix": "todos"
  },
  "Why": {
    "body": "**Why?**",
    "description": "Answer to Why I Cancelled a Task",
    "prefix": "why"
  },
  "bold": {
    "body": "**$0**",
    "prefix": "b"
  },
  "callout": {
    "body": "> [!$0",
    "prefix": "callout"
  },
  "checkbox": {
    "body": "- [ ] $0",
    "prefix": "td"
  },
  "code": {
    "body": ["```$0", "", "```"],
    "prefix": "c"
  },
  "h1": {
    "body": "# $0",
    "prefix": "h1"
  },
  "h2": {
    "body": "## $0",
    "prefix": "h2"
  },
  "h3": {
    "body": "### $0",
    "prefix": "h3"
  },
  "h4": {
    "body": "#### $0",
    "prefix": "h4"
  },
  "h5": {
    "body": "##### $0",
    "prefix": "h5"
  },
  "h6": {
    "body": "###### $0",
    "prefix": "h6"
  },
  "hr": {
    "body": "---",
    "prefix": "hr"
  },
  "ignore": {
    "body": "<!-- prettier-ignore -->",
    "prefix": "ignore"
  },
  "ignoreEnd": {
    "body": "<!-- prettier-ignore-end -->",
    "description": "Stylua ignore end range",
    "prefix": "igend"
  },
  "ignoreStart": {
    "body": "<!-- prettier-ignore-start -->",
    "prefix": "igstart"
  },
  "inline-code": {
    "body": "`$1` $0",
    "prefix": "ic"
  },
  "italic": {
    "body": "_$0_",
    "prefix": "i"
  },
  "list": {
    "body": "- $0",
    "prefix": ","
  },
  "note": {
    "body": [
      "## ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}, ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
      "",
      "- $0"
    ],
    "description": "Note for track things on my projects",
    "prefix": "note"
  },
  "theo vod": {
    "body": "- _${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}_ ${CLIPBOARD}",
    "prefix": "vod"
  },
  "today date": {
    "body": "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
    "prefix": "#today date"
  },
  "today time": {
    "body": "${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
    "prefix": "#today time"
  },
  "today timestamp": {
    "body": "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}, ${CURRENT_HOUR}:${CURRENT_MINUTE}:${CURRENT_SECOND}",
    "prefix": "#today timestamp"
  }
}
