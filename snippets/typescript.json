{
  "Create an anonymous function": {
    "body": ["const ${1:name} = (${2:params}): any => {", "\t$0", "};"],
    "description": "Create an anonymous function",
    "prefix": "afn"
  },
  "console.dir": {
    "body": "console.dir($0, { depth: null });",
    "description": "Recursively print an object",
    "prefix": "cd"
  },
  "console.log": {
    "body": "console.log($0);",
    "prefix": "cl"
  },
  "fn": {
    "body": ["function ${1:name}(${2:params}): any {", "\t$0", "};"],
    "prefix": "fn"
  },
  "wait": {
    "body": [
      "export async function wait(ms: number): Promise<void> {",
      "  return new Promise((resolve) => setTimeout(resolve, ms));",
      "}"
    ],
    "prefix": "wait"
  }
}
