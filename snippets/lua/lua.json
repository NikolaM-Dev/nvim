{
  "function": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:params})", "\t${0}", "end"],
    "description": "Define a function"
  },
  "anonymous function": {
    "prefix": "afn",
    "body": ["function (${1:params})", "\t${0}", "end"],
    "description": "Create an anonymous function"
  },
  "g": {
    "prefix": "g",
    "body": "_G.",
    "description": "Lua global variables"
  },
  "ignoreStart": {
    "prefix": "igstart",
    "body": "-- stylua: ignore start",
    "description": "Stylua ignore start range"
  },
  "ignoreEnd": {
    "prefix": "igend",
    "body": "-- stylua: ignore end",
    "description": "Stylua ignore end range"
  },
  "plugin": {
    "prefix": "plugin",
    "body": [
      "---@module 'lazy.types'",
      "---@type LazySpec",
      "return {",
      "\t'$0',",
      "\tdesc = '',",
      "",
      "\tconfig = true",
      "}"
    ]
  },

  "lang": {
    "prefix": "lang",
    "body": [
      "---@module 'lazy.types'",
      "---@type LazySpec",
      "return {",
      "\t{",
      "\t\t'nvim-treesitter/nvim-treesitter',",
      "\t\topts = function(_, opts)",
      "\t\t\tvim.list_extend(opts.languages, { '$1' })",
      "\t\tend,",
      "\t},",
      "\t{",
      "\t\t'williamboman/mason.nvim',",
      "\t\topts = function(_, opts)",
      "\t\t\tvim.list_extend(opts.ensure_installed, { '$2' })",
      "\t\tend,",
      "\t},",
      "\t{",
      "\t\t'neovim/nvim-lspconfig',",
      "\t\topts = function(_, opts)",
      "\t\t\topts.servers['$3'] = {}",
      "\t\tend,",
      "\t},",
      "\t{",
      "\t\t'stevearc/conform.nvim',",
      "\t\topts = function(_, opts)",
      "\t\t\topts.formatters_by_ft['$3'] = { '$4' }",
      "\t\tend,",
      "\t},",
      "\t{",
      "\t\t'mfussenegger/nvim-dap',",
      "\t\t---@param opts nkl.debug",
      "\t\topts = function(_, opts)",
      "\t\t\topts.adapters['$5'] = {},",
      "\t\t\topts.configurations['$3'] = {",
      "\t\t\t\t-- config #1",
      "\t\t\t},",
      "\t\tend,",
      "\t},",
      "",
      "\t-- TODO: testing",
      "}",
      "$0"
    ],
    "description": "Base setup for langs"
  },
  "Class": {
    "body": [
      "---@class ${1:ClassName}",
      "local ${1:ClassName} = {",
      "\t---@return ${1:ClassName}",
      "\tnew = function(self, newObj) -- https://www.lua.org/pil/16.1.html",
      "\t\tnewObj = newObj or {}",
      "\t\tsetmetatable(newObj, { __index = self })",
      "\t\treturn newObj",
      "\tend,",
      "}"
    ],
    "prefix": "Class (metatable)"
  }
}
